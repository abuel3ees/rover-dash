# Rover Pi Client Configuration
# Copy this file to .env and update with your values

# ─────────────────────────────────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────────────────────────────────

# Dashboard API endpoint
API_URL=http://192.168.1.100:8000/api

# API token from dashboard settings
API_TOKEN=your-api-token-here

# Unique name for this rover
ROVER_NAME=rover-01

# Enable debug logging
DEBUG=false

# ─────────────────────────────────────────────────────────────────────────
# Hardware Configuration
# ─────────────────────────────────────────────────────────────────────────

# Enable/disable features
CAMERA_ENABLED=true

# Telemetry update interval (seconds)
TELEMETRY_INTERVAL=1

# ─────────────────────────────────────────────────────────────────────────
# Advanced Settings (optional, see config.py for all options)
# ─────────────────────────────────────────────────────────────────────────

# Maximum motor speed (0-100)
MAX_MOTOR_SPEED=100

# Idle timeout before auto-stop (seconds)
IDLE_TIMEOUT=30

# Temperature warnings (Celsius)
TEMP_WARNING=65
TEMP_CRITICAL=80

# Battery warnings (percentage)
BATTERY_WARNING=25
BATTERY_CRITICAL=10
